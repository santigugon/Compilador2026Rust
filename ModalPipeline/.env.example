# Copy to .env and fill in (never commit .env)
#   cp .env.example .env

# Required for Modal model download (Hugging Face)
HF_TOKEN=hf_your_token_here
HUGGING_FACE_HUB_TOKEN=hf_your_token_here

# Modal secret object name (must match app.py / modal secret create)
MODAL_HF_SECRET_NAME=hf-token

# Optional: re-push .env values to Modal before each experiment run
SYNC_SECRETS_ON_RUN=1
